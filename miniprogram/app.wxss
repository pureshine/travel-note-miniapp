page {
  min-height: 100vh;
  background: #fff8ef;
  color: #2f2f2a;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  letter-spacing: 0;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  width: auto;
  min-width: 0;
  max-width: 100%;
  background: transparent;
  border: 0;
  border-radius: 0;
  line-height: 1.2;
  font-size: 28rpx;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  width: 100%;
  overflow-x: hidden;
  padding: 28rpx 36rpx;
  padding-bottom: 48rpx;
}

.muted {
  color: #9a9185;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 34rpx 2rpx 18rpx;
  color: #2f2f2a;
  font-size: 32rpx;
  font-weight: 700;
}

.panel {
  border: 2rpx solid rgba(220, 185, 145, 0.22);
  border-radius: 34rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(132, 105, 76, 0.06);
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 28rpx;
  background: #ff8a4c;
  color: #ffffff;
  font-weight: 700;
}

.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
  border: 2rpx solid rgba(255, 138, 76, 0.26);
  border-radius: 28rpx;
  background: #fff1df;
  color: #e66d35;
  font-weight: 700;
}

.field {
  min-height: 84rpx;
  width: 100%;
  padding: 0 24rpx;
  border: 2rpx solid #f0dfca;
  border-radius: 26rpx;
  background: #fffaf3;
  color: #2f2f2a;
}

.textarea {
  min-height: 180rpx;
  padding: 22rpx 24rpx;
  line-height: 1.55;
}

.empty {
  padding: 48rpx 24rpx;
  text-align: center;
  color: #80908a;
}
