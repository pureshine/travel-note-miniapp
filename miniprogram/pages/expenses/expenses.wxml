<view class="page" wx:if="{{trip}}">
  <view class="plan-switch panel">
    <picker mode="selector" range="{{tripNames}}" value="{{activeTripIndex}}" bindchange="onTripChange">
      <view class="plan-picker">
        <view class="plan-label">当前计划</view>
        <view class="plan-name">{{trip.name}}</view>
        <view class="plan-date">{{trip.destination}} · {{trip.startDate}} - {{trip.endDate}}</view>
      </view>
    </picker>
  </view>

  <view class="summary panel">
    <text class="summary-label">当前旅行花费</text>
    <view class="summary-value">¥{{total}}</view>
    <text class="summary-trip">{{trip.name}}</text>
  </view>

  <view class="form panel">
    <input class="field" placeholder="消费名称，比如晚餐、打车" value="{{title}}" bindinput="onTitleInput" />
    <view class="form-row">
      <input class="field" type="digit" placeholder="金额" value="{{amount}}" bindinput="onAmountInput" />
      <picker mode="selector" range="{{categories}}" bindchange="onCategoryChange">
        <view class="picker-field">{{category}}</view>
      </picker>
    </view>
    <input class="field" placeholder="付款人" value="{{paidBy}}" bindinput="onPaidByInput" />
    <button class="primary-button" bindtap="addItem">记录消费</button>
  </view>

  <view class="section-title">
    <text>明细</text>
  </view>
  <view class="list panel">
    <view wx:for="{{trip.expenses}}" wx:key="id" class="expense-row">
      <view class="expense-actions">
        <button class="expense-action edit" catchtap="editExpense" data-id="{{item.id}}">编辑</button>
        <button class="expense-action danger" catchtap="deleteExpense" data-id="{{item.id}}">删除</button>
      </view>
      <view
        class="expense-swipe {{openExpenseId === item.id ? 'open' : ''}}"
        bindtouchstart="onExpenseTouchStart"
        bindtouchmove="onExpenseTouchMove"
        data-id="{{item.id}}"
      >
        <view class="expense-main">
          <view class="expense-title">{{item.title}}</view>
          <view class="expense-meta">{{item.category}} · {{item.paidBy}}</view>
        </view>
        <view class="expense-side">
          <view class="expense-amount">¥{{item.amount}}</view>
        </view>
      </view>
    </view>
    <view wx:if="{{trip.expenses.length === 0}}" class="empty">还没有消费记录</view>
  </view>
</view>
