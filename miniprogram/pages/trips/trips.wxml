<view class="page">
  <view class="top-row">
    <view>
      <view class="title">我的旅行</view>
      <view class="muted">按一次旅行收纳所有出行信息</view>
    </view>
    <button class="add-button" bindtap="addTrip">+</button>
  </view>

  <view class="trip-list">
    <view wx:for="{{trips}}" wx:key="id" class="trip-row panel" bindtap="openTrip" data-id="{{item.id}}">
      <view class="trip-accent {{item.coverTone}}"></view>
      <view class="trip-main">
        <view class="trip-name">{{item.name}}</view>
        <view class="trip-meta">{{item.destination}} · {{item.startDate}} - {{item.endDate}}</view>
      </view>
      <view class="trip-side">
        <view class="trip-count">{{item.expenses.length}} 笔</view>
        <view class="trip-actions">
          <button class="text-action" catchtap="editTrip" data-id="{{item.id}}">编辑</button>
          <button class="text-action danger" catchtap="deleteTrip" data-id="{{item.id}}">删除</button>
        </view>
      </view>
    </view>
  </view>
</view>
