.memo-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.title {
  color: #2f2f2a;
  font-size: 48rpx;
  font-weight: 850;
}

.memo-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.memo-duck {
  width: 46rpx;
  height: 46rpx;
}

.memo-add {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-width: 210rpx;
  height: 76rpx;
  padding: 0 18rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #fff5d6 0%, #fff1df 100%);
  color: #d97949;
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: inset 0 -6rpx 0 rgba(255, 138, 76, 0.08);
}

.memo-add::after {
  border: 0;
}

.memo-add-text,
.memo-add-plus {
  line-height: 1;
  white-space: nowrap;
}

.memo-add-plus {
  font-size: 30rpx;
}

.memo-foot {
  width: 34rpx;
  height: 34rpx;
}

.empty-duck-foot {
  display: block;
  width: 116rpx;
  height: 116rpx;
  margin: 0 auto 12rpx;
}

.plan-switch {
  padding: 18rpx;
  margin-bottom: 22rpx;
}

.plan-picker {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
  min-height: 76rpx;
  padding: 0 18rpx;
  border-radius: 26rpx;
  background: #fff8ef;
}

.plan-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #ff8a4c;
  box-shadow: 0 0 0 8rpx rgba(255, 138, 76, 0.14);
}

.plan-copy {
  flex: 1;
  min-width: 0;
}

.plan-label {
  color: #b5a696;
  font-size: 20rpx;
  font-weight: 800;
}

.plan-name {
  margin-top: 6rpx;
  overflow: hidden;
  color: #2f2f2a;
  font-size: 28rpx;
  font-weight: 850;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plan-change {
  color: #ff8a4c;
  font-size: 23rpx;
  font-weight: 850;
  white-space: nowrap;
}

.filter-scroll {
  width: 100%;
  margin-bottom: 22rpx;
  white-space: nowrap;
}

.filter-row {
  display: flex;
  gap: 8rpx;
  padding: 8rpx;
  border-radius: 30rpx;
  background: #fff4e8;
  box-shadow: inset 0 0 0 1rpx rgba(240, 223, 202, 0.58);
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 98rpx;
  height: 54rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  background: transparent;
  color: #a79a8b;
  font-size: 24rpx;
  font-weight: 800;
}

.filter-chip.active {
  background: #ff9d6a;
  color: #ffffff;
  box-shadow: 0 8rpx 16rpx rgba(255, 138, 76, 0.16);
}

.form {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 22rpx;
}

.picker-field {
  display: flex;
  align-items: center;
  min-height: 84rpx;
  padding: 0 24rpx;
  border: 2rpx solid #f0dfca;
  border-radius: 26rpx;
  background: #fffaf3;
  color: #e66d35;
  font-weight: 800;
}

.note-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.note-card {
  position: relative;
  overflow: hidden;
  padding: 0;
}

.note-swipe {
  position: relative;
  z-index: 1;
  padding: 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  transition: transform 0.18s ease;
}

.note-swipe.open {
  transform: translateX(-220rpx);
}

.note-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  display: grid;
  grid-template-columns: repeat(2, 110rpx);
  width: 220rpx;
  overflow: hidden;
  border-radius: 0 28rpx 28rpx 0;
}

.note-action {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 850;
}

.note-action.edit {
  background: #ffad6d;
}

.note-action.danger {
  background: #ef6b5b;
}

.note-top {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.check-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border: 4rpx solid #eadbc8;
  border-radius: 14rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
}

.note-title {
  color: #2f2f2a;
  font-size: 32rpx;
  font-weight: 800;
}

.note-main {
  flex: 1;
  min-width: 0;
}

.note-content {
  margin-top: 8rpx;
  color: #a79a8b;
  font-size: 26rpx;
  line-height: 1.6;
}

.note-tag {
  padding: 9rpx 16rpx;
  border-radius: 16rpx;
  background: #fff1df;
  color: #e66d35;
  font-size: 23rpx;
  font-weight: 800;
}

.note-card.done {
  opacity: 0.58;
}

.note-card.done .check-dot {
  border-color: #ff8a4c;
  background: #ff8a4c;
}

.note-card.done .note-title,
.note-card.done .note-content {
  color: #8a9691;
}
