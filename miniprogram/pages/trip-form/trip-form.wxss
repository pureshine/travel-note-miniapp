.form-page {
  background: #fff8ef;
}

.form-title {
  color: #2f2f2a;
  font-size: 46rpx;
  font-weight: 850;
}

.form-subtitle {
  margin-top: 12rpx;
  color: #a79a8b;
  font-size: 26rpx;
  line-height: 1.55;
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 24rpx;
  margin-top: 28rpx;
}

.picker-field {
  display: flex;
  align-items: center;
  min-height: 84rpx;
  padding: 0 24rpx;
  border: 1rpx solid #dfe8e4;
  border-radius: 20rpx;
  background: #f8fbff;
  color: #e66d35;
  font-weight: 800;
}
