<view class="page profile-edit-page">
  <view class="profile-card panel">
    <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{avatarUrl}}" class="avatar-image" src="{{avatarUrl}}" mode="aspectFit" />
      <image wx:else class="avatar-image" src="/assets/illustrations/duck-avatar.png" mode="aspectFit" />
    </button>
    <view class="profile-title">个人资料</view>
    <view class="profile-subtitle">好友共享和记录人会使用这个显示名字</view>
  </view>

  <view class="form-card panel">
    <view class="field-label">显示名字</view>
    <input class="name-input" value="{{nickname}}" bindinput="onNameInput" maxlength="16" placeholder="比如 小陈、阿圆、旅行搭子" />

    <view class="info-row">
      <text>最近同步</text>
      <text>{{lastSyncText}}</text>
    </view>
    <view class="info-row">
      <text>账号状态</text>
      <text>微信已登录</text>
    </view>
  </view>

  <button class="save-button" loading="{{saving}}" bindtap="saveProfile">保存资料</button>
  <button class="logout-text" bindtap="logout">退出登录</button>
</view>
