.profile-edit-page {
  background: #fff8ef;
}

.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 28rpx 34rpx;
  background: linear-gradient(135deg, #ffe6bf 0%, #fff6df 58%, #edf7e9 100%);
}

.avatar-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 150rpx;
  height: 150rpx;
  padding: 0;
  overflow: hidden;
  border: 8rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 34rpx;
  background: #ffffff;
  color: #f0753d;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 150rpx;
  box-shadow: 0 14rpx 32rpx rgba(139, 93, 54, 0.12);
}

.avatar-picker::after,
.save-button::after,
.logout-text::after {
  border: 0;
}

.avatar-image {
  width: 100%;
  height: 100%;
  background: #ffffff;
}

.profile-title {
  margin-top: 22rpx;
  color: #2f2f2a;
  font-size: 38rpx;
  font-weight: 900;
}

.profile-subtitle {
  margin-top: 10rpx;
  color: #8f8171;
  font-size: 24rpx;
  font-weight: 700;
}

.form-card {
  padding: 26rpx;
  margin-top: 24rpx;
}

.field-label {
  color: #8f8171;
  font-size: 24rpx;
  font-weight: 850;
}

.name-input {
  height: 88rpx;
  margin-top: 14rpx;
  padding: 0 24rpx;
  border-radius: 26rpx;
  background: #fff8ef;
  color: #2f2f2a;
  font-size: 30rpx;
  font-weight: 850;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 68rpx;
  margin-top: 16rpx;
  color: #9b8d7c;
  font-size: 24rpx;
  font-weight: 750;
}

.info-row text:last-child {
  overflow: hidden;
  color: #5f554b;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.save-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 86rpx;
  margin-top: 28rpx;
  border-radius: 30rpx;
  background: #ff8a4c;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 86rpx;
  box-shadow: 0 14rpx 28rpx rgba(255, 126, 75, 0.18);
}

.logout-text {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  margin-top: 12rpx;
  color: #a07f63;
  font-size: 24rpx;
  font-weight: 850;
}
