<view class="page">
  <view class="brand panel">
    <view class="brand-mark">鸭</view>
    <view>
      <view class="brand-title">冲鸭去旅行</view>
      <view class="muted">旅行日程、清单、备忘和消费统计</view>
    </view>
  </view>

  <view class="section-title">
    <text>数据</text>
  </view>
  <view class="settings-list panel">
    <button class="settings-row" bindtap="resetData">
      <view>
        <view class="settings-title">清空旅行数据</view>
        <view class="settings-desc">删除本机旅行、清单、备忘和消费，从 0 开始测试</view>
      </view>
      <text class="settings-arrow">›</text>
    </button>
  </view>

  <view class="section-title">
    <text>开发计划</text>
  </view>
  <view class="roadmap panel">
    <view class="roadmap-item">本地存储首版</view>
    <view class="roadmap-item">接入微信云开发</view>
    <view class="roadmap-item">同行人分账和导出</view>
  </view>
</view>
