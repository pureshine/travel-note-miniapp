.form-page {
  background: #fff8ef;
}

.form-title {
  color: #2f2f2a;
  font-size: 46rpx;
  font-weight: 850;
}

.form-subtitle {
  margin-top: 12rpx;
  color: #a79a8b;
  font-size: 26rpx;
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 24rpx;
  margin-top: 28rpx;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.picker-field {
  display: flex;
  align-items: center;
  min-height: 84rpx;
  padding: 0 24rpx;
  border: 2rpx solid #f0dfca;
  border-radius: 26rpx;
  background: #fffaf3;
  color: #e66d35;
  font-weight: 800;
}

.image-row {
  width: 100%;
  white-space: nowrap;
}

.preview-image {
  display: inline-block;
  width: 180rpx;
  height: 120rpx;
  margin-right: 14rpx;
  border-radius: 24rpx;
  background: #f4eee6;
  vertical-align: top;
}

.upload-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 180rpx;
  height: 120rpx;
  border: 2rpx dashed #e9c7a5;
  border-radius: 24rpx;
  background: #fffaf3;
  color: #e66d35;
  font-size: 22rpx;
  font-weight: 800;
  vertical-align: top;
}

.upload-card.wide {
  width: 100%;
}

.upload-plus {
  font-size: 42rpx;
  line-height: 1;
  margin-bottom: 6rpx;
}
