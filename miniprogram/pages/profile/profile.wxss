.profile-page {
  background: #fff8ef;
}

.profile-hero {
  padding: 28rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #ffe6bf 0%, #fff6df 56%, #e9f6e8 100%);
  box-shadow: 0 18rpx 48rpx rgba(139, 93, 54, 0.1);
}

.hero-topline {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 98rpx;
  height: 98rpx;
  border-radius: 34rpx;
  background: #ffffff;
  color: #f0753d;
  font-size: 42rpx;
  font-weight: 900;
  box-shadow: inset 0 -8rpx 0 rgba(255, 138, 76, 0.12);
}

.brand-duck,
.avatar-placeholder {
  width: 90rpx;
  height: 90rpx;
}

.avatar-button {
  display: flex;
  flex: 0 0 98rpx;
  align-items: center;
  justify-content: center;
  width: 98rpx;
  min-width: 98rpx;
  max-width: 98rpx;
  height: 98rpx;
  padding: 0;
  overflow: hidden;
  border-radius: 34rpx;
  background: #ffffff;
  color: #f0753d;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 98rpx;
  box-shadow: inset 0 -8rpx 0 rgba(255, 138, 76, 0.12);
}

.avatar-button::after {
  border: 0;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.profile-name {
  color: #2f2f2a;
  font-size: 36rpx;
  font-weight: 900;
}

.profile-subtitle {
  margin-top: 8rpx;
  color: #8f8171;
  font-size: 24rpx;
  font-weight: 750;
}

.profile-arrow {
  color: #c99b74;
  font-size: 46rpx;
  font-weight: 500;
  line-height: 1;
}

.state-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #aa9b8b;
  font-size: 22rpx;
  font-weight: 800;
}

.state-pill.online {
  background: #dcf8e7;
  color: #32aa68;
}

.login-actions {
  display: block;
  margin-top: 28rpx;
}

.login-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  font-weight: 900;
}

.login-button {
  background: linear-gradient(135deg, #ff9f66 0%, #ff7d4b 100%);
  color: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(255, 126, 75, 0.22);
}

.login-button::after,
.logout-button::after {
  border: 0;
}

.logout-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 168rpx;
  height: 64rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #d97949;
  font-size: 23rpx;
  font-weight: 900;
}

.overview-grid {
  display: grid;
  grid-template-columns: 0.82fr 0.92fr 1.26fr;
  gap: 14rpx;
  margin-top: 22rpx;
}

.mini-card {
  padding: 22rpx 18rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 38rpx rgba(139, 93, 54, 0.07);
}

.mini-card.wide {
  grid-column: span 1;
}

.mini-value {
  overflow: hidden;
  color: #2f2f2a;
  font-size: 28rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-value.sync-time {
  font-size: 25rpx;
  letter-spacing: 0;
}

.mini-label {
  margin-top: 8rpx;
  color: #a79a8b;
  font-size: 22rpx;
  font-weight: 700;
}

.sync-card {
  position: relative;
  overflow: hidden;
  margin-top: 24rpx;
  padding: 28rpx;
}

.card-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.sync-title {
  color: #2f2f2a;
  font-size: 34rpx;
  font-weight: 900;
}

.sync-desc {
  margin-top: 8rpx;
  color: #8f8171;
  font-size: 24rpx;
}

.sync-badge {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 74rpx;
  height: 74rpx;
  padding: 0;
  border-radius: 24rpx;
  background: #fff6df;
  overflow: hidden;
  box-shadow: inset 0 -6rpx 0 rgba(255, 181, 108, 0.1);
}

.sync-badge-duck {
  width: 66rpx;
  height: 66rpx;
}

.sync-tip {
  position: relative;
  z-index: 1;
  margin-top: 10rpx;
  color: #a07f63;
  font-size: 23rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.invite-strip {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: #fff8ef;
}

.invite-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  border-radius: 24rpx;
  background: #ff8a4c;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
}

.invite-copy {
  flex: 1;
  min-width: 0;
}

.invite-title {
  color: #2f2f2a;
  font-size: 28rpx;
  font-weight: 900;
}

.invite-desc {
  overflow: hidden;
  margin-top: 8rpx;
  color: #8f8171;
  font-size: 23rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  margin-top: 14rpx;
  padding: 0 8rpx;
}

.member-label {
  flex: 0 0 auto;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #fff1cf;
  color: #d97949;
  font-size: 21rpx;
  font-weight: 850;
}

.member-names {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #8f8171;
  font-size: 23rpx;
  font-weight: 750;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sync-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.primary-action,
.soft-action,
.share-action,
.text-action {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  border-radius: 28rpx;
  font-size: 25rpx;
  font-weight: 900;
}

.primary-action {
  background: #ff8a4c;
  color: #ffffff;
}

.soft-action {
  background: #fff1cf;
  color: #e66d35;
}

.soft-action.full {
  width: 100%;
  margin-top: 22rpx;
}

.share-action {
  width: 100%;
  margin-top: 14rpx;
  background: #8fd7b0;
  color: #ffffff;
}

.text-action {
  width: 100%;
  margin-top: 12rpx;
  background: transparent;
  color: #a07f63;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 22rpx;
}

.tool-card {
  padding: 24rpx;
}

.tool-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 62rpx;
  height: 62rpx;
  border-radius: 22rpx;
  background: #fff1cf;
  color: #e66d35;
  font-size: 30rpx;
  font-weight: 900;
}

.tool-title {
  margin-top: 16rpx;
  color: #2f2f2a;
  font-size: 27rpx;
  font-weight: 900;
}

.tool-desc {
  margin-top: 8rpx;
  color: #8f8171;
  font-size: 23rpx;
  line-height: 1.45;
}

.profile-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 36rpx;
  background: rgba(52, 39, 26, 0.28);
}

.profile-sheet {
  width: 100%;
  padding: 34rpx 30rpx 28rpx;
  border-radius: 36rpx;
  background: #fffaf3;
  box-shadow: 0 24rpx 60rpx rgba(86, 61, 39, 0.18);
}

.sheet-title {
  color: #2f2f2a;
  font-size: 34rpx;
  font-weight: 900;
  text-align: center;
}

.sheet-subtitle {
  margin-top: 8rpx;
  color: #8f8171;
  font-size: 24rpx;
  text-align: center;
}

.setup-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 132rpx;
  margin: 28rpx auto 22rpx;
  overflow: hidden;
  border-radius: 42rpx;
  background: #fff1cf;
  color: #e66d35;
  font-size: 24rpx;
  font-weight: 900;
}

.setup-avatar::after,
.setup-save::after,
.setup-skip::after {
  border: 0;
}

.setup-avatar-image {
  width: 100%;
  height: 100%;
}

.setup-nickname {
  width: 100%;
  height: 82rpx;
  padding: 0 24rpx;
  border-radius: 26rpx;
  background: #ffffff;
  color: #2f2f2a;
  font-size: 28rpx;
  font-weight: 800;
}

.setup-save {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  margin-top: 20rpx;
  border-radius: 28rpx;
  background: #ff8a4c;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 900;
}

.setup-skip {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 70rpx;
  margin-top: 10rpx;
  color: #a07f63;
  font-size: 24rpx;
  font-weight: 800;
}
