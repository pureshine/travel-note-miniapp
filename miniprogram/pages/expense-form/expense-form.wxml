<view class="page form-page" wx:if="{{trip}}">
  <view class="form-title">新增消费</view>
  <view class="form-subtitle">{{trip.name}} · {{trip.destination}}</view>

  <view class="form-card panel">
    <input class="field" placeholder="消费名称，如 一兰拉面" value="{{title}}" bindinput="onTitleInput" />
    <input class="field" type="digit" placeholder="金额" value="{{amount}}" bindinput="onAmountInput" />
    <picker mode="selector" range="{{categories}}" bindchange="onCategoryChange">
      <view class="picker-field">分类：{{category}}</view>
    </picker>
    <input class="field" placeholder="付款人" value="{{paidBy}}" bindinput="onPaidByInput" />
    <button class="primary-button" bindtap="saveExpense">保存消费</button>
  </view>
</view>
