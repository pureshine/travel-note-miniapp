<view class="page form-page" wx:if="{{trip}}">
  <view class="form-title">新增备忘</view>
  <view class="form-subtitle">{{trip.name}} · {{trip.destination}}</view>

  <view class="form-card panel">
    <input class="field" placeholder="标题，如 购买旅行保险" value="{{title}}" bindinput="onTitleInput" />
    <picker mode="selector" range="{{categories}}" bindchange="onCategoryChange">
      <view class="picker-field">分类：{{category}}</view>
    </picker>
    <textarea class="field textarea" placeholder="写下具体事项、截止时间或提醒" value="{{content}}" bindinput="onContentInput" />
    <button class="primary-button" bindtap="saveNote">保存备忘</button>
  </view>
</view>
