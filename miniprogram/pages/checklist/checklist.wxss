.header {
  margin-bottom: 24rpx;
}

.title {
  color: #172521;
  font-size: 44rpx;
  font-weight: 850;
}

.form {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 22rpx;
  margin-bottom: 22rpx;
}

.list {
  padding: 8rpx 24rpx;
}

.check-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 94rpx;
  border-bottom: 1rpx solid #edf2ef;
  color: #172521;
  font-size: 30rpx;
}

.check-row:last-child {
  border-bottom: 0;
}

.check-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border: 2rpx solid #b8c8c1;
  border-radius: 50%;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
}

.check-row.done {
  color: #91a09a;
}

.check-row.done .check-dot {
  border-color: #167c70;
  background: #167c70;
}
