.schedule-page {
  background: #f6f9fd;
}

.weather-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  min-height: 128rpx;
  padding: 24rpx 30rpx;
}

.weather-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 82rpx;
  height: 82rpx;
  border-radius: 22rpx;
  background: #fff8e8;
  color: #f59e0b;
  font-size: 28rpx;
  font-weight: 850;
}

.weather-title {
  color: #101828;
  font-size: 31rpx;
  font-weight: 850;
}

.weather-sub {
  margin-top: 8rpx;
  color: #98a6ba;
  font-size: 25rpx;
}

.sun-time {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  color: #8ea0b8;
  font-size: 24rpx;
  text-align: right;
}

.form {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 22rpx;
  margin-top: 22rpx;
}

.plan-bar {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  padding: 22rpx 26rpx;
  margin-top: 22rpx;
}

.plan-picker {
  min-width: 0;
}

.plan-name {
  overflow: hidden;
  color: #101828;
  font-size: 32rpx;
  font-weight: 850;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plan-date {
  margin-top: 8rpx;
  color: #98a6ba;
  font-size: 24rpx;
  line-height: 1.35;
}

.plan-actions {
  display: flex;
  gap: 12rpx;
  width: 100%;
  overflow: hidden;
}

.mini-button {
  display: flex;
  flex: 1 1 0;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  max-width: 100%;
  height: 64rpx;
  padding: 0 12rpx;
  border-radius: 18rpx;
  background: #eef5ff;
  color: #3b82f6;
  font-size: 24rpx;
  font-weight: 850;
  line-height: 64rpx;
  white-space: nowrap;
}

.mini-button.primary {
  background: #3b82f6;
  color: #ffffff;
}

.form-row {
  display: grid;
  grid-template-columns: 190rpx 1fr;
  gap: 18rpx;
}

.time-field {
  text-align: center;
}

.picker-field {
  display: flex;
  align-items: center;
  min-height: 84rpx;
  padding: 0 24rpx;
  border: 1rpx solid #dfe8e4;
  border-radius: 20rpx;
  background: #fbfdfc;
  color: #3b82f6;
  font-weight: 800;
}

.timeline {
  padding: 14rpx 0 14rpx 20rpx;
  background: transparent;
  border: 0;
  box-shadow: none;
}

.timeline-row {
  display: grid;
  grid-template-columns: 88rpx 36rpx 1fr;
  gap: 18rpx;
  padding: 18rpx 0;
}

.timeline-row.active .event {
  border: 4rpx solid #d8e8ff;
}

.time-block {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.time {
  color: #8ea0b8;
  font-size: 27rpx;
  font-weight: 850;
}

.status {
  margin-top: 12rpx;
  padding: 7rpx 10rpx;
  border-radius: 10rpx;
  background: #eef5ff;
  color: #3b82f6;
  font-size: 20rpx;
  font-weight: 800;
}

.status.done {
  background: #eafaf4;
  color: #5cc99a;
}

.status.active {
  background: #eef5ff;
  color: #3b82f6;
}

.status.pending {
  background: #f1f5f9;
  color: #8ea0b8;
}

.line {
  position: relative;
  display: flex;
  justify-content: center;
}

.line::after {
  content: "";
  position: absolute;
  top: 24rpx;
  bottom: -28rpx;
  width: 2rpx;
  background: #dce8e3;
  background: #dbe5f3;
}

.timeline-row:last-child .line::after {
  display: none;
}

.dot {
  position: relative;
  z-index: 1;
  width: 18rpx;
  height: 18rpx;
  margin-top: 8rpx;
  border: 6rpx solid #deebff;
  border-radius: 50%;
  background: #3b82f6;
}

.event-wrap {
  position: relative;
  min-width: 0;
  overflow: hidden;
  border-radius: 28rpx;
}

.event {
  position: relative;
  z-index: 1;
  padding: 28rpx 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 44rpx rgba(45, 68, 102, 0.06);
  transition: transform 0.18s ease;
}

.event.open {
  transform: translateX(-220rpx);
}

.event-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  display: grid;
  grid-template-columns: repeat(2, 110rpx);
  width: 220rpx;
  overflow: hidden;
  border-radius: 0 28rpx 28rpx 0;
}

.swipe-action {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 850;
}

.swipe-action.edit {
  background: #3b82f6;
}

.swipe-action.danger {
  background: #dc2626;
}

.event-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.category {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #3b82f6;
  font-size: 22rpx;
  font-weight: 800;
}

.place {
  overflow: hidden;
  color: #98a6ba;
  font-size: 24rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.event-title {
  color: #101828;
  font-size: 31rpx;
  font-weight: 800;
}

.event-note {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.55;
}

.image-row {
  width: 100%;
  margin-top: 18rpx;
  white-space: nowrap;
}

.event-image {
  display: inline-block;
  width: 180rpx;
  height: 112rpx;
  margin-right: 12rpx;
  border-radius: 18rpx;
  background: #eef2f7;
}
