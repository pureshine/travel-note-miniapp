.schedule-page {
  background: #fff8ef;
}

.tip-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 128rpx;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #fffaf3 0%, #fff4df 58%, #eef8ed 100%);
}

.tip-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 82rpx;
  height: 82rpx;
  border-radius: 22rpx;
  overflow: hidden;
  background: #fff6df;
  box-shadow: inset 0 -6rpx 0 rgba(255, 181, 108, 0.1);
}

.tip-icon-cat {
  width: 78rpx;
  height: 78rpx;
}

.tip-title {
  color: #2f2f2a;
  font-size: 31rpx;
  font-weight: 850;
}

.tip-sub {
  margin-top: 8rpx;
  color: #a79a8b;
  font-size: 25rpx;
}

.tip-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  color: #a79a8b;
  font-size: 24rpx;
  text-align: right;
}

.form {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 22rpx;
  margin-top: 22rpx;
}

.plan-card {
  padding: 18rpx;
  margin-top: 22rpx;
  background: linear-gradient(135deg, #fffaf3 0%, #fff4e8 58%, #eef8ed 100%);
}

.plan-main {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 108rpx;
  align-items: center;
  gap: 14rpx;
}

.plan-picker {
  min-width: 0;
}

.plan-pill {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
  min-height: 76rpx;
  padding: 0 14rpx 0 18rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.68);
  box-shadow: inset 0 0 0 1rpx rgba(240, 223, 202, 0.78);
}

.plan-dot {
  flex: 0 0 auto;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #ff8a4c;
  box-shadow: 0 0 0 8rpx rgba(255, 138, 76, 0.14);
}

.plan-dot.done {
  background: #b8ad9e;
  box-shadow: 0 0 0 8rpx rgba(184, 173, 158, 0.16);
}

.plan-dot.upcoming {
  background: #ff8a4c;
}

.plan-copy {
  flex: 1;
  min-width: 0;
}

.plan-label {
  color: #b5a696;
  font-size: 20rpx;
  font-weight: 800;
}

.plan-name {
  overflow: hidden;
  color: #2f2f2a;
  font-size: 28rpx;
  font-weight: 850;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plan-change {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #fff4df;
  color: #b58b6a;
  font-size: 20rpx;
  font-weight: 850;
  white-space: nowrap;
}

.status-pill {
  flex: 0 0 auto;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 850;
  white-space: nowrap;
}

.status-pill.upcoming {
  background: #fff4df;
  color: #d97949;
}

.status-pill.done {
  background: #f0ede8;
  color: #8f8171;
}

.plan-menu {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 76rpx;
  padding: 0;
  border-radius: 26rpx;
  background: #edf7e9;
  color: #5f8a70;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 76rpx;
}

.plan-menu::after,
.quick-add::after {
  border: 0;
}

.quick-add {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  margin-top: 16rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #ffaf78 0%, #ff8958 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 76rpx;
  box-shadow: 0 12rpx 24rpx rgba(255, 126, 75, 0.16);
}

.form-row {
  display: grid;
  grid-template-columns: 190rpx 1fr;
  gap: 18rpx;
}

.time-field {
  text-align: center;
}

.picker-field {
  display: flex;
  align-items: center;
  min-height: 84rpx;
  padding: 0 24rpx;
  border: 2rpx solid #f0dfca;
  border-radius: 26rpx;
  background: #fffaf3;
  color: #e66d35;
  font-weight: 800;
}

.timeline {
  padding: 14rpx 0 14rpx 20rpx;
  background: transparent;
  border: 0;
  box-shadow: none;
}

.year-label {
  display: inline-flex;
  align-items: center;
  height: 52rpx;
  margin: 18rpx 0 4rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #fff1cf;
  color: #9a6b42;
  font-size: 24rpx;
  font-weight: 900;
  white-space: nowrap;
}

.timeline-row {
  display: grid;
  grid-template-columns: 98rpx 28rpx minmax(0, 1fr);
  gap: 14rpx;
  padding: 18rpx 0;
}

.timeline-row.active .event {
  border: 4rpx solid #ffd9bd;
}

.time-block {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  min-width: 0;
}

.time {
  color: #a79a8b;
  font-size: 27rpx;
  font-weight: 850;
}

.day {
  color: #b8aa9a;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.25;
  white-space: nowrap;
}

.status {
  margin-top: 12rpx;
  padding: 7rpx 10rpx;
  border-radius: 10rpx;
  background: #fff1df;
  color: #e66d35;
  font-size: 20rpx;
  font-weight: 800;
}

.status.done {
  background: #eafaf4;
  color: #64b883;
}

.status.active {
  background: #fff1df;
  color: #e66d35;
}

.status.pending {
  background: #f4eee6;
  color: #a79a8b;
}

.line {
  position: relative;
  display: flex;
  justify-content: center;
}

.line::after {
  content: "";
  position: absolute;
  top: 24rpx;
  bottom: -28rpx;
  width: 2rpx;
  background: #eadbc8;
}

.timeline-row:last-child .line::after {
  display: none;
}

.dot {
  position: relative;
  z-index: 1;
  width: 18rpx;
  height: 18rpx;
  margin-top: 8rpx;
  border: 6rpx solid #fff1df;
  border-radius: 50%;
  background: #ff8a4c;
}

.event-wrap {
  position: relative;
  min-width: 0;
  overflow: hidden;
  border-radius: 28rpx;
}

.event {
  position: relative;
  z-index: 1;
  padding: 28rpx 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(132, 105, 76, 0.06);
  transition: transform 0.18s ease;
}

.event.open {
  transform: translateX(-220rpx);
}

.event-actions {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  display: grid;
  grid-template-columns: repeat(2, 110rpx);
  width: 220rpx;
  overflow: hidden;
  border-radius: 0 28rpx 28rpx 0;
}

.swipe-action {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 850;
}

.swipe-action.edit {
  background: #ffad6d;
}

.swipe-action.danger {
  background: #ef6b5b;
}

.event-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.category {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #fff1df;
  color: #e66d35;
  font-size: 22rpx;
  font-weight: 800;
}

.place {
  overflow: hidden;
  color: #a79a8b;
  font-size: 24rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.event-title {
  color: #2f2f2a;
  font-size: 31rpx;
  font-weight: 800;
}

.event-note {
  margin-top: 10rpx;
  color: #746a60;
  font-size: 24rpx;
  line-height: 1.55;
}

.image-row {
  width: 100%;
  margin-top: 18rpx;
  white-space: nowrap;
}

.event-image {
  display: inline-block;
  width: 180rpx;
  height: 112rpx;
  margin-right: 12rpx;
  border-radius: 18rpx;
  background: #f4eee6;
}
