.stats-page {
  background: #fff8ef;
}

.plan-switch {
  padding: 18rpx;
  margin-bottom: 22rpx;
}

.plan-picker {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
  min-height: 76rpx;
  padding: 0 18rpx;
  border-radius: 26rpx;
  background: #fff8ef;
}

.plan-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #ff8a4c;
  box-shadow: 0 0 0 8rpx rgba(255, 138, 76, 0.14);
}

.plan-copy {
  flex: 1;
  min-width: 0;
}

.plan-label {
  color: #b5a696;
  font-size: 20rpx;
  font-weight: 800;
}

.plan-name {
  margin-top: 6rpx;
  overflow: hidden;
  color: #2f2f2a;
  font-size: 28rpx;
  font-weight: 850;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plan-change {
  color: #ff8a4c;
  font-size: 23rpx;
  font-weight: 850;
  white-space: nowrap;
}

.budget-card {
  padding: 32rpx;
}

.budget-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.budget-label {
  color: #a79a8b;
  font-size: 24rpx;
}

.budget-total {
  margin: 12rpx 0;
  color: #2f2f2a;
  font-size: 58rpx;
  font-weight: 850;
}

.budget-side {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding-top: 10rpx;
  color: #a79a8b;
  font-size: 24rpx;
  text-align: right;
}

.budget-track {
  height: 16rpx;
  margin-top: 18rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #f4eee6;
}

.budget-progress {
  height: 100%;
  border-radius: 999rpx;
  background: #ff8a4c;
}

.quick-expense {
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr) 112rpx;
  align-items: center;
  gap: 18rpx;
  min-height: 118rpx;
  padding: 22rpx;
  margin-top: 22rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #fffaf3 0%, #fff4e8 58%, #eef8ed 100%);
}

.quick-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: #fff6df;
  box-shadow: inset 0 -6rpx 0 rgba(255, 181, 108, 0.1);
}

.quick-paw {
  width: 46rpx;
  height: 46rpx;
}

.quick-main {
  min-width: 0;
}

.quick-title {
  overflow: hidden;
  min-width: 0;
  color: #2f2f2a;
  font-size: 29rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quick-subtitle {
  margin-top: 8rpx;
  overflow: hidden;
  color: #a79a8b;
  font-size: 22rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  min-width: 0;
  max-width: 112rpx;
  height: 68rpx;
  border-radius: 24rpx;
  background: #ff8a4c;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 850;
  line-height: 68rpx;
}

.record-button::after {
  border: 0;
}

.recent-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recent-card {
  display: grid;
  grid-template-columns: 62rpx minmax(0, 1fr) 104rpx 112rpx;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 20rpx;
}

.recent-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: #fff1df;
  color: #e66d35;
  font-size: 19rpx;
  font-weight: 850;
}

.recent-main {
  flex: 1;
  min-width: 0;
}

.recent-title {
  overflow: hidden;
  margin-bottom: 8rpx;
  color: #2f2f2a;
  font-size: 25rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-amount {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  align-self: stretch;
  color: #2f2f2a;
  font-size: 27rpx;
  font-weight: 900;
  white-space: nowrap;
}

.recent-meta {
  color: #a79a8b;
  font-size: 22rpx;
}

.recent-tools {
  display: flex;
  gap: 8rpx;
  justify-content: flex-end;
}

.tool-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50rpx;
  height: 50rpx;
  border-radius: 16rpx;
  background: #fff1df;
  color: #e66d35;
  font-size: 20rpx;
  font-weight: 850;
}

.tool-button.danger {
  background: #fff0ee;
  color: #e35f4f;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.category-chip {
  padding: 16rpx;
  border-radius: 26rpx;
}

.chip-head {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
  color: #a79a8b;
  font-size: 20rpx;
  font-weight: 800;
}

.chip-amount {
  margin-top: 8rpx;
  color: #2f2f2a;
  font-size: 24rpx;
  font-weight: 850;
}
