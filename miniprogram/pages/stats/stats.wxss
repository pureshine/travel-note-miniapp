.stats-page {
  background: #fff8ef;
}

.plan-switch {
  padding: 18rpx;
  margin-bottom: 22rpx;
}

.plan-picker {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
  min-height: 76rpx;
  padding: 0 18rpx;
  border-radius: 26rpx;
  background: #fff8ef;
}

.plan-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #ff8a4c;
  box-shadow: 0 0 0 8rpx rgba(255, 138, 76, 0.14);
}

.plan-copy {
  flex: 1;
  min-width: 0;
}

.plan-label {
  color: #b5a696;
  font-size: 20rpx;
  font-weight: 800;
}

.plan-name {
  margin-top: 6rpx;
  overflow: hidden;
  color: #2f2f2a;
  font-size: 28rpx;
  font-weight: 850;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plan-change {
  color: #ff8a4c;
  font-size: 23rpx;
  font-weight: 850;
  white-space: nowrap;
}

.ledger-hero {
  padding: 22rpx;
  background: linear-gradient(135deg, #fffaf3 0%, #fff4e8 56%, #eef8ed 100%);
}

.budget-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border: 2rpx solid rgba(226, 189, 160, 0.34);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.72);
}

.budget-ring {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  height: 70rpx;
  border: 7rpx solid #78c8bd;
  border-radius: 50%;
  background: #ffffff;
}

.ring-value {
  color: #5a9e94;
  font-size: 20rpx;
  font-weight: 900;
}

.budget-main {
  flex: 1;
  min-width: 0;
}

.budget-title {
  color: #2f2f2a;
  font-size: 28rpx;
  font-weight: 900;
}

.budget-sub {
  margin-top: 6rpx;
  color: #a79a8b;
  font-size: 23rpx;
  font-weight: 750;
}

.budget-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  color: #a79a8b;
  font-size: 23rpx;
  font-weight: 750;
  text-align: right;
}

.budget-edit {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 70rpx;
  height: 38rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #fff4df;
  color: #d97949;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 38rpx;
  white-space: nowrap;
}

.hero-total-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
}

.budget-label {
  color: #a79a8b;
  font-size: 24rpx;
  font-weight: 750;
}

.budget-total {
  margin-top: 8rpx;
  color: #2f2f2a;
  font-size: 56rpx;
  font-weight: 900;
  line-height: 1.05;
}

.hero-add {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 162rpx;
  height: 72rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #ff9d6a;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 72rpx;
  box-shadow: 0 12rpx 24rpx rgba(255, 138, 76, 0.18);
}

.hero-add::after {
  border: 0;
}

.daily-chart {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 10rpx;
  align-items: end;
  height: 172rpx;
  margin-top: 14rpx;
  padding: 0 2rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  min-width: 0;
}

.bar-amount {
  min-height: 24rpx;
  color: #8f8171;
  font-size: 17rpx;
  font-weight: 850;
  line-height: 24rpx;
  white-space: nowrap;
}

.bar-track {
  display: flex;
  align-items: flex-end;
  width: 32rpx;
  height: 90rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(120, 200, 189, 0.12);
}

.bar-fill {
  width: 100%;
  min-height: 8rpx;
  border-radius: 999rpx;
  background: #8bd2c7;
}

.bar-item.active .bar-fill {
  background: #ff9d6a;
}

.bar-label {
  color: #a79a8b;
  font-size: 18rpx;
  font-weight: 750;
  white-space: nowrap;
}

.calendar-card {
  padding: 26rpx;
  margin-top: 22rpx;
}

.calendar-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.calendar-title {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 14rpx;
  border-radius: 18rpx;
  background: #fffaf3;
  color: #2f2f2a;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 52rpx;
  white-space: nowrap;
}

.month-control {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.month-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  padding: 0;
  border-radius: 18rpx;
  background: #fff4df;
  color: #d97949;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 52rpx;
}

.month-arrow::after {
  border: 0;
}

.calendar-sub {
  margin-top: 8rpx;
  color: #a79a8b;
  font-size: 22rpx;
  font-weight: 750;
}

.calendar-total {
  flex: 0 0 auto;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #fff4df;
  color: #d97949;
  font-size: 22rpx;
  font-weight: 850;
}

.week-row,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 8rpx;
}

.week-row {
  margin-bottom: 10rpx;
  color: #c0b4a7;
  font-size: 20rpx;
  font-weight: 850;
  text-align: center;
}

.calendar-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 78rpx;
  border-radius: 22rpx;
  background: #f7fbf8;
  color: #5f554b;
}

.calendar-day.muted {
  opacity: 0.32;
}

.calendar-day.has-amount {
  background: #e7f6f2;
}

.calendar-day.high {
  background: #bdebe5;
}

.calendar-day.today {
  box-shadow: inset 0 0 0 3rpx rgba(120, 200, 189, 0.42);
}

.calendar-day.selected {
  background: #ffb98e;
  color: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(255, 138, 76, 0.18);
}

.day-number {
  font-size: 24rpx;
  font-weight: 900;
}

.day-amount {
  min-height: 22rpx;
  margin-top: 4rpx;
  font-size: 16rpx;
  font-weight: 800;
}

.month-trend {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(240, 223, 202, 0.72);
}

.trend-title {
  color: #2f2f2a;
  font-size: 25rpx;
  font-weight: 900;
}

.recent-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-meta {
  color: #a79a8b;
  font-size: 24rpx;
  font-weight: 800;
}

.recent-card {
  display: grid;
  grid-template-columns: 62rpx minmax(0, 1fr) 104rpx 112rpx;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 20rpx;
}

.recent-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: #fff1df;
  color: #e66d35;
  font-size: 19rpx;
  font-weight: 850;
}

.recent-main {
  flex: 1;
  min-width: 0;
}

.recent-title {
  overflow: hidden;
  margin-bottom: 8rpx;
  color: #2f2f2a;
  font-size: 25rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-amount {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  align-self: stretch;
  color: #2f2f2a;
  font-size: 27rpx;
  font-weight: 900;
  white-space: nowrap;
}

.recent-meta {
  color: #a79a8b;
  font-size: 22rpx;
}

.recent-tools {
  display: flex;
  gap: 8rpx;
  justify-content: flex-end;
}

.tool-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50rpx;
  height: 50rpx;
  border-radius: 16rpx;
  background: #fff1df;
  color: #e66d35;
  font-size: 20rpx;
  font-weight: 850;
}

.tool-button.danger {
  background: #fff0ee;
  color: #e35f4f;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.category-chip {
  padding: 16rpx;
  border-radius: 26rpx;
}

.chip-head {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
  color: #a79a8b;
  font-size: 20rpx;
  font-weight: 800;
}

.chip-amount {
  margin-top: 8rpx;
  color: #2f2f2a;
  font-size: 24rpx;
  font-weight: 850;
}
