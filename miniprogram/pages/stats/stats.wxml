<view class="page stats-page">
  <view class="plan-switch panel" wx:if="{{trip}}">
    <picker mode="selector" range="{{tripNames}}" value="{{activeTripIndex}}" bindchange="onTripChange">
      <view class="plan-picker">
        <view class="plan-dot"></view>
        <view class="plan-copy">
          <view class="plan-label">当前计划</view>
          <view class="plan-name">{{trip.name}}</view>
        </view>
        <view class="plan-change">切换 ▾</view>
      </view>
    </picker>
  </view>

  <view class="ledger-hero panel">
    <view class="budget-card" bindtap="goBudgetForm">
      <view class="budget-ring">
        <view class="ring-value">{{budgetPercent}}%</view>
      </view>
      <view class="budget-main">
        <view class="budget-title">本次预算</view>
        <view class="budget-sub">支出预算 ¥{{budget}}</view>
      </view>
      <view class="budget-side">
        <text>可用 ¥{{remaining}}</text>
        <text class="budget-edit">设置</text>
      </view>
    </view>
    <view class="hero-total-row">
      <view>
        <view class="budget-label">本次总支出</view>
        <view class="budget-total">¥{{expenseTotal}}</view>
      </view>
      <button class="hero-add" bindtap="goExpenseForm">+ 记一笔</button>
    </view>
  </view>

  <view class="calendar-card panel" bindtouchstart="onCalendarTouchStart" bindtouchend="onCalendarTouchEnd">
    <view class="calendar-head">
      <view>
        <view class="month-control">
          <button class="month-arrow" bindtap="prevMonth">‹</button>
          <picker class="month-picker" mode="date" fields="month" value="{{calendarMonthValue}}" bindchange="onMonthChange">
            <view class="calendar-title">{{calendarTitle}} ▾</view>
          </picker>
          <button class="month-arrow" bindtap="nextMonth">›</button>
        </view>
        <view class="calendar-sub">点选日期查看流水</view>
      </view>
      <view class="calendar-total">本日 ¥{{selectedDateExpenseTotal}}</view>
    </view>
    <view class="week-row">
      <text wx:for="{{weekLabels}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="calendar-grid">
      <view
        wx:for="{{calendarDays}}"
        wx:key="dateKey"
        class="{{item.className}}"
        data-date="{{item.dateKey}}"
        bindtap="selectCalendarDay"
      >
        <text class="day-number">{{item.day}}</text>
        <text class="day-amount">{{item.amountText}}</text>
      </view>
    </view>
    <view class="month-trend">
      <view class="trend-title">近期消费曲线</view>
      <view class="daily-chart">
        <view wx:for="{{dailyBars}}" wx:key="label" class="bar-item {{item.active ? 'active' : ''}}">
          <view class="bar-amount">{{item.amountText}}</view>
          <view class="bar-track">
            <view class="bar-fill" style="height: {{item.height}}%;"></view>
          </view>
          <view class="bar-label">{{item.label}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section-title">
    <text>{{selectedDateTitle}}流水</text>
    <text class="section-meta">支出 ¥{{selectedDateExpenseTotal}}</text>
  </view>
  <view class="recent-list">
    <view wx:for="{{selectedDateExpenses}}" wx:key="id" class="recent-card panel">
      <view class="recent-icon">{{item.category}}</view>
      <view class="recent-main">
        <view class="recent-title">{{item.title}}</view>
        <view class="recent-meta">{{item.category}} · {{item.paidBy}}</view>
      </view>
      <view class="recent-amount">¥{{item.amount}}</view>
      <view class="recent-tools">
        <button class="tool-button" catchtap="editExpense" data-id="{{item.id}}">改</button>
        <button class="tool-button danger" catchtap="deleteExpense" data-id="{{item.id}}">删</button>
      </view>
    </view>
    <view wx:if="{{selectedDateExpenses.length === 0}}" class="empty panel">这天还没有消费记录</view>
  </view>

  <view class="section-title">
    <text>分类概览</text>
  </view>
  <view class="category-grid">
    <view wx:for="{{categories}}" wx:key="category" class="category-chip panel">
      <view class="chip-head">
        <text>{{item.category}}</text>
        <text>{{item.percent}}%</text>
      </view>
      <view class="chip-amount">¥{{item.amount}}</view>
    </view>
  </view>
</view>
