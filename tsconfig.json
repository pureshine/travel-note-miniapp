{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "alwaysStrict": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "miniprogram/*": ["miniprogram/*"]
    },
    "typeRoots": ["./miniprogram/types"]
  },
  "include": ["miniprogram/**/*.ts", "scripts/**/*.js"]
}
